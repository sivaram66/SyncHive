# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, or self-hosted)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Redis ───────────────────────────────────────────────────────────────────
# Redis/Upstash URL for BullMQ queue and SSE pub/sub
REDIS_URL=rediss://default:password@host:6379

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Auth ────────────────────────────────────────────────────────────────────
# Change this to a long random string in production (openssl rand -base64 32)
JWT_SECRET=change-me-in-production

# ─── Observability (optional) ────────────────────────────────────────────────
# Honeycomb.io distributed tracing — leave blank to disable
HONEYCOMB_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io/v1/traces

# ─── Integrations ────────────────────────────────────────────────────────────
# Email — Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Slack — default webhook URL used when node config doesn't specify one
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Discord — default webhook URL (optional, can also be set per-node in config)
DISCORD_WEBHOOK_URL=

# AI — Groq (FREE at https://console.groq.com/keys)
# Supports: llama-3.3-70b-versatile, llama-3.1-8b-instant, gemma2-9b-it, mixtral-8x7b-32768
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
